# Server port (optional, defaults to 3000)
PORT=3000

# --- Codeforces API credentials ------------------------------------------------
# Create keys at https://codeforces.com/settings/api
# The cf module signs requests and rotates across every pair you provide,
# failing over to the next pair when one hits the call limit (issue #9).
#
# Primary pair:
API_KEY=your_codeforces_api_key
API_SECRET=your_codeforces_api_secret
#
# Add more pairs to raise throughput / provide failover (up to _10):
# API_KEY_2=second_codeforces_api_key
# API_SECRET_2=second_codeforces_api_secret
#
# Or supply extra pairs as a JSON list (combined with the ones above):
# CF_CREDENTIALS=[{"key":"key1","secret":"secret1"},{"key":"key2","secret":"secret2"}]
#
# Note: CodeChef needs no credentials — its cards are crawled from the public
# profile page (issue #8).
